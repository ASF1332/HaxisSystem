{
  "compilerOptions": {
    "target": "es2016", // Versão do JavaScript que será gerada
    "module": "commonjs", // Sistema de módulos do Node.js
    "rootDir": "./src", // Onde está seu código TypeScript
    "outDir": "./dist", // Onde o código JavaScript compilado será salvo
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true, // Habilita checagens mais rigorosas para evitar erros
    "skipLibCheck": true
  }
}